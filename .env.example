# ─── Required Environment Variables ─────────────────────────────────────────
# Add these to your Vercel project: Settings → Environment Variables

# DATABASE_URL: Neon PostgreSQL connection string (required for all API routes).
# Get from: https://console.neon.tech → your project → Connection Details → Connection string
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# GEMINI_API_KEY: Required for Gemini AI features (optional if not using AI).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The deployed URL (e.g. https://nikahpath.vercel.app). Used for OAuth callbacks.
APP_URL="https://your-app.vercel.app"

